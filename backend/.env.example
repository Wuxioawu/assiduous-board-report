POSTGRES_USER=assiduous
POSTGRES_PASSWORD=assiduous
POSTGRES_DB=assiduous_board_report
POSTGRES_HOST=localhost
# Matches docker-compose.yml's host port mapping (5433 by default, to avoid
# clashing with a locally-installed Postgres on 5432).
POSTGRES_PORT=5433

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

CORS_ORIGINS=http://localhost:5173

# Required for AI extraction (backend/app/services/extraction) - get a key at
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
